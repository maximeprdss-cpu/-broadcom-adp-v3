module.exports = async function(req, res) {
  if (req.method !== 'POST') {
    res.status(405).json({ error: 'Method not allowed' });
    return;
  }
  try {
    var data = req.body;
    var buffer = await generateDocx(data);
    var filename = (data.produit || 'ADP') + '_Adoption_Plan_' + (data.accountName || 'Document').replace(/[^a-zA-Z0-9]/g, '_') + '.docx';
    res.setHeader('Content-Type', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document');
    res.setHeader('Content-Disposition', 'attachment; filename="' + filename + '"');
    res.send(buffer);
  } catch (err) {
    console.error(err);
    res.status(500).json({ error: err.message });
  }
};

// Override the export to fix fontTable relationship
const originalModule = module.exports;
module.exports = async function(req, res) {
  if (req.method !== 'POST') { res.status(405).json({ error: 'Method not allowed' }); return; }
  try {
    const data = req.body;
    let buffer = await generateDocx(data);
    
    // Fix fontTable relationship using JSZip
    const JSZip = require('jszip');
    const zip = await JSZip.loadAsync(buffer);
    const relsFile = 'word/_rels/document.xml.rels';
    let rels = await zip.file(relsFile).async('string');
    if (!rels.includes('fontTable')) {
      rels = rels.replace('</Relationships>', 
        '  <Relationship Id="rId99" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/fontTable" Target="fontTable.xml"/>\n</Relationships>');
      zip.file(relsFile, rels);
    }
    buffer = await zip.generateAsync({ type: 'nodebuffer', compression: 'DEFLATE' });
    
    const filename = (data.produit || 'ADP') + '_Adoption_Plan_' + (data.accountName || 'Document').replace(/[^a-zA-Z0-9]/g, '_') + '.docx';
    res.setHeader('Content-Type', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document');
    res.setHeader('Content-Disposition', 'attachment; filename="' + filename + '"');
    res.send(buffer);
  } catch (err) { console.error(err); res.status(500).json({ error: err.message }); }
};

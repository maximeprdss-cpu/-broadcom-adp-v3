const {
  Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell,
  Header, Footer, AlignmentType, HeadingLevel, BorderStyle, WidthType,
  ShadingType, VerticalAlign, LevelFormat, TabStopType, TabStopPosition,
  PageBreak
} = require('docx');

const RED    = 'CC092F';
const DARK   = '1C2833';
const WHITE  = 'FFFFFF';
const GREY   = 'F2F3F4';
const BORD   = 'CCCCCC';
const W      = 9360;
const FONT   = 'Arial';

const border  = { style: BorderStyle.SINGLE, size: 1, color: BORD };
const borders = { top: border, bottom: border, left: border, right: border };

function cell(text, opts) {
  opts = opts || {};
  var cw = opts.w || 4680, isHeader = opts.header || false, fill = opts.fill || null;
  var bold = opts.bold || false, sz = opts.size || 20;
  return new TableCell({
    borders,
    width: { size: cw, type: WidthType.DXA },
    shading: fill ? { fill, type: ShadingType.CLEAR } : undefined,
    margins: { top: 80, bottom: 80, left: 120, right: 120 },
    verticalAlign: VerticalAlign.CENTER,
    children: [new Paragraph({
      children: [new TextRun({
        text: text || '',
        bold: bold || isHeader,
        size: sz,
        color: isHeader ? WHITE : DARK,
        font: FONT,
      })]
    })]
  });
}

function makeTable(headers, rows, colWidths) {
  var hRow = new TableRow({
    tableHeader: true,
    children: headers.map(function(h, i) {
      return cell(h, { w: colWidths[i], header: true, fill: DARK, size: 18 });
    })
  });
  var dRows = rows.map(function(row, ri) {
    return new TableRow({
      children: row.map(function(txt, ci) {
        return cell(txt, { w: colWidths[ci], fill: ri % 2 === 0 ? WHITE : GREY, size: 18 });
      })
    });
  });
  return new Table({ width: { size: W, type: WidthType.DXA }, columnWidths: colWidths, rows: [hRow].concat(dRows) });
}

function sectionTitle(text) {
  return new Paragraph({
    heading: HeadingLevel.HEADING_2,
    spacing: { before: 300, after: 120 },
    border: { bottom: { style: BorderStyle.SINGLE, size: 8, color: RED, space: 4 } },
    children: [new TextRun({ text, bold: true, size: 28, color: RED, font: FONT })]
  });
}

function field(label, value) {
  return new Paragraph({
    spacing: { before: 40, after: 40 },
    children: [
      new TextRun({ text: label + ' ', bold: true, size: 20, color: DARK, font: FONT }),
      new TextRun({ text: value || 'N/A', size: 20, color: DARK, font: FONT }),
    ]
  });
}

function instruction(text) {
  return new Paragraph({
    spacing: { before: 80, after: 80 },
    children: [new TextRun({ text, italics: true, size: 18, color: '7F8C8D', font: FONT })]
  });
}

function blank(text) {
  return new Paragraph({
    spacing: { before: 80, after: 160 },
    shading: { fill: 'FFF9F9', type: ShadingType.CLEAR },
    border: {
      top: { style: BorderStyle.DASHED, size: 4, color: 'FFAAAA', space: 2 },
      bottom: { style: BorderStyle.DASHED, size: 4, color: 'FFAAAA', space: 2 },
    },
    children: [new TextRun({ text, italics: true, size: 18, color: 'AAAAAA', font: FONT })]
  });
}

function sp(before) {
  return new Paragraph({ spacing: { before: before || 120, after: 0 }, children: [new TextRun('')] });
}

function bullet(text) {
  return new Paragraph({
    numbering: { reference: 'bullets', level: 0 },
    spacing: { before: 40, after: 40 },
    children: [new TextRun({ text, size: 20, color: DARK, font: FONT })]
  });
}

